# .env.local 예시
# Host 앱 포트
PORT=5173 # 해당하는 포트로 적용

# Vite Base URL (default: /)
VITE_BASE_URL=/

# Vite Router Base Name (default: /)
VITE_ROUTER_BASENAME=/

# 외부 API 기본 URL (테스트용)
VITE_EXTERNAL_API_BASE_URL1=https://koreanjson.com
VITE_EXTERNAL_API_BASE_URL2=https://jsonplaceholder.typicode.com

# API 서버 기본 URL (Vite dev proxy: /api → localhost:4000)
VITE_API_BASE_URL=/api