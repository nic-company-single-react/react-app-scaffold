# .env.local 예시
# Host 앱 포트
PORT=5173 # 해당하는 포트로 적용

# Vite Base URL (default: /)
VITE_BASE_URL=/

# Vite Router Base Name (default: /)
VITE_ROUTER_BASENAME=/

# JWT를 이용한 access token 저장 이름 설정(미사용 시 공백처리)
VITE_LOCALSTORAGE_TOKEN_NAME=access_token

# local server url
VITE_SERVER_URL=http://localhost:4000

# API 서버 기본 URL (Vite dev proxy: /api → localhost:4000)
# 임시 api 호출 url (https://jsonplaceholder.typicode.com)
VITE_API_BASE_URL=https://jsonplaceholder.typicode.com
