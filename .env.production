# .env.local 예시
# Host 앱 포트
PORT=5173 # 해당하는 포트로 적용

# Vite Base URL (default: /)
VITE_BASE_URL=/axiom/react

# Vite Router Base Name (default: /)
VITE_ROUTER_BASENAME=/

# JWT를 이용한 access token 저장 이름 설정(미사용 시 공백처리)
VITE_LOCALSTORAGE_TOKEN_NAME=access_token

# 테마(라이트/다크) 저장 localStorage 키 이름 (index.html FOUC 스크립트와 공유하는 단일 소스)
VITE_THEME_STORAGE_KEY=theme

# local server url
VITE_SERVER_URL=

# API 서버 기본 URL
VITE_API_BASE_URL=/